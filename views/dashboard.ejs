<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>RBAC Dashboard</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />

  <style>
    body {
      background: #f8fafc;
      font-family: 'Inter', sans-serif;
    }

    .dashboard-header {
      background: #4f46e5;
      color: white;
      border-radius: 16px;
      padding: 20px;
    }

    .card {
      border: none;
      border-radius: 14px;
      box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    }

    .stat-card {
      padding: 20px;
      border-radius: 14px;
      background: white;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .stat-icon {
      width: 45px;
      height: 45px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #eef2ff;
      color: #4f46e5;
      font-size: 20px;
    }

    .perm-badge {
      font-size: 12px;
      border-radius: 8px;
      padding: 6px 10px;
    }

    .quick-btn {
      border-radius: 12px;
      padding: 15px;
      background: white;
      text-align: center;
      transition: 0.2s;
      border: 1px solid #e5e7eb;
    }

    .quick-btn:hover {
      background: #eef2ff;
      transform: translateY(-3px);
    }
  </style>
</head>

<body>

  <%- include('layouts/navbar') %>

  <div class="container mt-4">

    <!-- Header -->
    <div class="dashboard-header mb-4">
      <h4 class="fw-bold mb-1">Welcome, <%= user.empName %></h4>
      <small>Your role: <span class="fw-semibold text-capitalize"><%= user.role %></span></small>
    </div>

    <!-- Stats -->
    <div class="row g-3 mb-4">
      <div class="col-md-4">
        <div class="stat-card shadow-sm ">
          <div>
            <small class="text-muted">Role</small>
            <h6 class="fw-bold text-capitalize mb-0"><%= user.role %></h6>
          </div>
          <div class="stat-icon"><i class="bi bi-person"></i></div>
        </div>
      </div>

      <div class="col-md-4">
        <div class="stat-card shadow-sm ">
          <div>
            <small class="text-muted">Department</small>
            <h6 class="fw-bold mb-0"><%= user.department %></h6>
          </div>
          <div class="stat-icon"><i class="bi bi-building"></i></div>
        </div>
      </div>

      <div class="col-md-4">
        <div class="stat-card shadow-sm ">
          <div>
            <small class="text-muted">Email</small>
            <h6 class="fw-bold mb-0"><%= user.empEmail %></h6>
          </div>
          <div class="stat-icon"><i class="bi bi-envelope"></i></div>
        </div>
      </div>
    </div>

    <!-- Permissions -->
    <div class="card p-4 mb-4">
      <h6 class="fw-bold mb-3">Permissions</h6>

      <div class="d-flex flex-wrap gap-2">
        <% allPermissions.forEach(function(perm) { %>
          <% var hasIt = permissions.includes(perm); %>

          <span class="perm-badge badge <%= hasIt ? 'bg-success' : 'bg-light text-muted border' %>">
            <%= perm %>
          </span>
        <% }); %>
      </div>
    </div>

    <!-- Quick Actions -->
    <div class="row g-3">

      <div class="col-md-4">
        <a href="/records-view" class="text-decoration-none">
          <div class="quick-btn">
            <i class="bi bi-folder2-open fs-4 text-primary"></i>
            <div class="fw-semibold mt-2">Manage Records</div>
          </div>
        </a>
      </div>

      <div class="col-md-4">
        <div class="quick-btn opacity-75">
          <i class="bi bi-bar-chart fs-4 text-secondary"></i>
          <div class="fw-semibold mt-2">Analytics</div>
        </div>
      </div>

      <div class="col-md-4">
        <div class="quick-btn opacity-75">
          <i class="bi bi-gear fs-4 text-secondary"></i>
          <div class="fw-semibold mt-2">Settings</div>
        </div>
      </div>

    </div>

  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>